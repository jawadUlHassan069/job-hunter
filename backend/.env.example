# ── Celery Configuration ────────────────────────────────────────────────────
# CELERY_ALWAYS_EAGER controls whether Celery tasks run synchronously or async
# 
# Development (default):
#   CELERY_ALWAYS_EAGER=True
#   - Tasks run inline (synchronously) without needing Redis or Celery worker
#   - Good for quick testing but BLOCKS HTTP responses during task execution
#   - ⚠️ Can cause UI freezing if tasks are triggered during login/API calls
#
# Production (recommended):
#   CELERY_ALWAYS_EAGER=False
#   - Tasks run asynchronously via Celery worker
#   - Requires Redis running: redis-server
#   - Requires Celery worker: celery -A config worker -l info
#   - Requires Celery beat: celery -A config beat -l info (for periodic tasks)
#   - Login is fast, scraping happens in background
#
CELERY_ALWAYS_EAGER=True

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

SENTRY_DSN=

JWT_SECRET_KEY=
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

OTP_TOTP_ISSUER=JobHunter